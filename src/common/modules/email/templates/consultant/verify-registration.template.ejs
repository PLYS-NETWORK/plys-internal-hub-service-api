<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Email Verification - Lona</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="margin: 0; padding: 0; background-color: #f7f9fb; font-family: 'Inter', sans-serif">
    <!-- Email Container -->
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="background-color: #f7f9fb; padding: 48px 0"
    >
      <tr>
        <td align="center">
          <!-- Header -->
          <table width="600" cellpadding="0" cellspacing="0" style="margin: 0 0 32px">
            <tr>
              <td align="center" style="padding: 32px 16px">
                <h1
                  style="
                    margin: 0;
                    font-family: 'Manrope', sans-serif;
                    font-size: 24px;
                    font-weight: 800;
                    letter-spacing: -0.025em;
                    color: #0040e0;
                  "
                >
                  Lona
                </h1>
              </td>
            </tr>
          </table>

          <!-- Main Content Card -->
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="
              background-color: #ffffff;
              border-radius: 12px;
              overflow: hidden;
              box-shadow: 0 20px 40px rgba(25, 28, 30, 0.04);
              border: 1px solid rgba(196, 197, 217, 0.15);
              position: relative;
            "
          >
            <!-- Decorative Background Element -->
            <tr>
              <td style="height: 0; position: relative">
                <div
                  style="
                    position: absolute;
                    top: -64px;
                    right: -64px;
                    width: 128px;
                    height: 128px;
                    background-color: #2e5bff;
                    border-radius: 50%;
                    opacity: 0.1;
                    filter: blur(48px);
                    z-index: 1;
                  "
                ></div>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 48px 32px; position: relative; z-index: 2">
                <!-- Icon -->
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 32px">
                  <tr>
                    <td
                      style="
                        width: 48px;
                        height: 48px;
                        background-color: #eceef0;
                        border-radius: 50%;
                        text-align: center;
                        vertical-align: middle;
                      "
                    >
                      <span style="color: #0040e0; font-size: 24px; line-height: 48px">✉</span>
                    </td>
                  </tr>
                </table>

                <!-- Headline -->
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 32px">
                  <tr>
                    <td>
                      <h2
                        style="
                          margin: 0 0 8px;
                          font-family: 'Manrope', sans-serif;
                          font-size: 24px;
                          font-weight: 700;
                          letter-spacing: -0.025em;
                          color: #191c1e;
                          line-height: 1.2;
                        "
                      >
                        Verify your email address
                      </h2>
                      <p
                        style="
                          margin: 0;
                          font-family: 'Inter', sans-serif;
                          font-size: 18px;
                          color: #434656;
                          line-height: 1.6;
                        "
                      >
                        Welcome to Lona, <strong><%= userName %></strong>. We're thrilled to have
                        you here.
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Body Text -->
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 32px">
                  <tr>
                    <td>
                      <p
                        style="
                          margin: 0 0 24px;
                          font-family: 'Inter', sans-serif;
                          font-size: 18px;
                          color: #434656;
                          line-height: 1.6;
                        "
                      >
                        To ensure the security of your account and to gain full access to the
                        platform's features, please verify your email address. This quick step helps
                        us keep the community safe and your projects secure.
                      </p>
                      <p
                        style="
                          margin: 0;
                          font-family: 'Inter', sans-serif;
                          font-size: 18px;
                          color: #434656;
                          line-height: 1.6;
                        "
                      >
                        Click the button below to confirm your address and step into your new
                        workspace. This link will expire in
                        <strong><%= expiryHours %> hours</strong>.
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- CTA Button -->
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 32px">
                  <tr>
                    <td>
                      <table
                        cellpadding="0"
                        cellspacing="0"
                        style="
                          background: linear-gradient(45deg, #0040e0, #2e5bff);
                          border-radius: 24px;
                          box-shadow: 0 4px 12px rgba(0, 64, 224, 0.2);
                        "
                      >
                        <tr>
                          <td style="text-align: center; padding: 16px 32px">
                            <a
                              href="<%= verificationUrl %>"
                              style="
                                display: inline-block;
                                color: #ffffff;
                                font-family: 'Inter', sans-serif;
                                font-size: 14px;
                                font-weight: 600;
                                text-decoration: none;
                                text-transform: uppercase;
                                letter-spacing: 0.05em;
                                width: 100%;
                              "
                            >
                              Verify Email
                            </a>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Fallback Link Section -->
                <table
                  cellpadding="0"
                  cellspacing="0"
                  style="
                    margin: 32px 0;
                    padding-top: 24px;
                    border-top: 1px solid rgba(224, 227, 229, 0.5);
                  "
                >
                  <tr>
                    <td>
                      <p
                        style="
                          margin: 0 0 16px;
                          font-family: 'Inter', sans-serif;
                          font-size: 14px;
                          color: #434656;
                          line-height: 1.5;
                        "
                      >
                        If you're having trouble clicking the button, copy and paste the URL below
                        into your web browser:
                      </p>
                      <table
                        cellpadding="0"
                        cellspacing="0"
                        style="
                          width: 100%;
                          background-color: #eceef0;
                          border-radius: 8px;
                          border: 1px solid rgba(196, 197, 217, 0.15);
                        "
                      >
                        <tr>
                          <td style="padding: 12px 16px">
                            <p
                              style="
                                margin: 0;
                                font-family: 'Inter', sans-serif;
                                font-size: 14px;
                                color: #0040e0;
                                line-height: 1.4;
                                word-break: break-all;
                              "
                            >
                              <%= verificationUrl %>
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Disclaimer -->
                <table cellpadding="0" cellspacing="0" style="margin: 32px 0 0">
                  <tr>
                    <td>
                      <p
                        style="
                          margin: 0;
                          font-family: 'Inter', sans-serif;
                          font-size: 14px;
                          color: #434656;
                          line-height: 1.5;
                        "
                      >
                        If you did not request this, you can safely ignore this email.
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>

          <!-- Footer -->
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="margin: 48px 0 0; text-align: center"
          >
            <tr>
              <td style="padding: 0 16px 40px">
                <table cellpadding="0" cellspacing="0" style="margin: 0 auto 16px">
                  <tr>
                    <td style="padding: 0 16px">
                      <a
                        href="#"
                        style="
                          font-family: 'Inter', sans-serif;
                          font-size: 12px;
                          color: #94a3b8;
                          text-decoration: underline;
                        "
                        >Privacy Policy</a
                      >
                    </td>
                    <td style="color: #cbd5e1; font-size: 12px">•</td>
                    <td style="padding: 0 16px">
                      <a
                        href="#"
                        style="
                          font-family: 'Inter', sans-serif;
                          font-size: 12px;
                          color: #94a3b8;
                          text-decoration: underline;
                        "
                        >Terms of Service</a
                      >
                    </td>
                    <td style="color: #cbd5e1; font-size: 12px">•</td>
                    <td style="padding: 0 16px">
                      <a
                        href="#"
                        style="
                          font-family: 'Inter', sans-serif;
                          font-size: 12px;
                          color: #94a3b8;
                          text-decoration: underline;
                        "
                        >Unsubscribe</a
                      >
                    </td>
                  </tr>
                </table>

                <p
                  style="
                    margin: 0;
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #94a3b8;
                  "
                >
                  © <%= year %> Lona. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
