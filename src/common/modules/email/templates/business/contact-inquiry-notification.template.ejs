<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New contact inquiry</title>
  </head>
  <body style="margin:0;padding:32px;background-color:#f7f9fb;font-family:'Inter',sans-serif;color:#0f172a">
    <table cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:600px;margin:0 auto;background:#ffffff;border-radius:16px;padding:32px">
      <tr>
        <td>
          <p style="font-family:monospace;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#64748b;margin:0 0 12px">Ployos · Contact</p>
          <h1 style="font-size:24px;font-weight:700;margin:0 0 16px">New <%= topicLabel %> inquiry</h1>
          <p style="margin:0 0 24px;color:#475569">A new inquiry was submitted via the public contact form.</p>

          <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:24px">
            <tr><td style="padding:8px 0;font-size:13px;color:#64748b;width:140px">Name</td><td style="padding:8px 0;font-size:14px"><%= name %></td></tr>
            <tr><td style="padding:8px 0;font-size:13px;color:#64748b">Email</td><td style="padding:8px 0;font-size:14px"><%= email %></td></tr>
            <tr><td style="padding:8px 0;font-size:13px;color:#64748b">Company</td><td style="padding:8px 0;font-size:14px"><%= company %></td></tr>
            <tr><td style="padding:8px 0;font-size:13px;color:#64748b">Topic</td><td style="padding:8px 0;font-size:14px"><%= topicLabel %></td></tr>
            <tr><td style="padding:8px 0;font-size:13px;color:#64748b">Submitted</td><td style="padding:8px 0;font-size:14px"><%= submittedAt %></td></tr>
            <tr><td style="padding:8px 0;font-size:13px;color:#64748b">IP</td><td style="padding:8px 0;font-size:14px"><%= ipAddress %></td></tr>
          </table>

          <div style="padding:16px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0">
            <p style="font-family:monospace;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#64748b;margin:0 0 8px">Message</p>
            <div style="font-size:14px;line-height:1.6;color:#0f172a"><%- messageHtml %></div>
          </div>

          <p style="margin:32px 0 0;font-size:12px;color:#94a3b8">© <%= year %> Ployos. Reply to this email to respond directly to the inquirer.</p>
        </td>
      </tr>
    </table>
  </body>
</html>
