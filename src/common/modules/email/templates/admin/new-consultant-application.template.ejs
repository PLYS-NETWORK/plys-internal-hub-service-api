<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Consultant Application</title>
  </head>
  <body style="margin: 0; padding: 0; background-color: #f7f9fb; font-family: 'Inter', sans-serif">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f7f9fb; padding: 32px 0">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 20px 40px rgba(25,28,30,0.04)">
            <tr>
              <td style="padding: 32px 32px 0; text-align: center; background-color: #f7f9fb">
                <h1 style="margin: 0; font-size: 24px; font-weight: 800; color: #0040e0">Plys Internal Hub</h1>
              </td>
            </tr>
            <tr>
              <td style="padding: 40px 32px">
                <h2 style="margin: 0 0 8px; font-size: 22px; font-weight: 700; color: #191c1e">New Consultant Application</h2>
                <p style="margin: 0 0 24px; font-size: 14px; color: #505f76">A consultant has completed their interview and is awaiting admin review.</p>
                <table cellpadding="0" cellspacing="0" style="width: 100%; background-color: #f7f9fb; border-radius: 8px; margin: 0 0 24px">
                  <tr>
                    <td style="padding: 20px">
                      <p style="margin: 0 0 8px; font-size: 14px; color: #505f76"><strong>Name:</strong> <%= consultantName %></p>
                      <p style="margin: 0 0 8px; font-size: 14px; color: #505f76"><strong>Email:</strong> <%= consultantEmail %></p>
                      <p style="margin: 0; font-size: 14px; color: #505f76"><strong>Submitted:</strong> <%= submittedAt %></p>
                    </td>
                  </tr>
                </table>
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 16px">
                  <tr>
                    <td style="background: linear-gradient(45deg, #0040e0, #2e5bff); border-radius: 24px; padding: 14px 32px">
                      <a href="<%= reviewUrl %>" style="color: #ffffff; font-size: 14px; font-weight: 700; text-decoration: none; text-transform: uppercase; letter-spacing: 0.05em">Review Application →</a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding: 24px 32px; text-align: center; background-color: #f7f9fb">
                <p style="margin: 0; font-size: 12px; color: #505f76">© <%= year %> Plys. Admin notification — do not reply.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
