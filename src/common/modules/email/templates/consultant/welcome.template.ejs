<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to Lona</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
</head>
<body style="margin:0;padding:0;background-color:#f7f9fb;font-family:'Inter',sans-serif;">

  <!-- Email Container -->
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f7f9fb;padding:32px 0;">
    <tr>
      <td align="center">

        <!-- Main Content Card -->
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 20px 40px rgba(25,28,30,0.04);">

          <!-- Header -->
          <tr>
            <td style="padding:32px 32px 0;text-align:center;background-color:#f7f9fb;">
              <h1 style="margin:0;font-family:'Manrope',sans-serif;font-size:24px;font-weight:800;letter-spacing:-0.025em;color:#0040e0;">Lona</h1>
            </td>
          </tr>

          <!-- Hero Section -->
          <tr>
            <td style="padding:0 32px 32px;">

              <!-- Hero Visual Area -->
              <table cellpadding="0" cellspacing="0" style="width:100%;height:200px;background-color:#f2f4f6;border-radius:12px;margin:32px 0;position:relative;overflow:hidden;">
                <tr>
                  <td style="position:relative;">
                    <!-- Gradient Background -->
                    <div style="width:100%;height:200px;background:linear-gradient(135deg, #f2f4f6 0%, #e6e8ea 50%, #dde1ff 100%);position:relative;">
                      <!-- Decorative Elements -->
                      <div style="position:absolute;top:20px;right:30px;width:60px;height:60px;background-color:#dde1ff;border-radius:50%;opacity:0.6;"></div>
                      <div style="position:absolute;bottom:30px;left:40px;width:40px;height:40px;background-color:#0040e0;border-radius:8px;opacity:0.1;"></div>
                      <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:80px;height:80px;background-color:#0040e0;border-radius:50%;opacity:0.08;"></div>
                      <!-- Welcome Icon -->
                      <div style="position:absolute;bottom:20px;right:20px;width:48px;height:48px;background-color:#ffffff;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(0,64,224,0.1);">
                        <span style="font-size:24px;color:#0040e0;">👋</span>
                      </div>
                    </div>
                  </td>
                </tr>
              </table>

              <!-- Welcome Text -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
                <tr>
                  <td>
                    <h2 style="margin:0 0 24px;font-family:'Manrope',sans-serif;font-size:32px;font-weight:700;letter-spacing:-0.025em;color:#191c1e;line-height:1.1;">
                      Welcome to the network,<br/>
                      <span style="color:#0040e0;"><%= userName %></span>.
                    </h2>
                    <p style="margin:0;font-family:'Inter',sans-serif;font-size:16px;color:#434656;line-height:1.6;">
                      We're thrilled to have you here. Lona is designed to seamlessly connect your expertise with projects that matter. No more endless searching—just meaningful work tailored to your skills.
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Value Props Section -->
          <tr>
            <td style="padding:24px 32px;background-color:rgba(242,244,246,0.5);">

              <!-- Curated Matches -->
              <table cellpadding="0" cellspacing="0" style="width:100%;background-color:#ffffff;border-radius:8px;margin:0 0 24px;box-shadow:0 2px 8px rgba(25,28,30,0.02);">
                <tr>
                  <td style="padding:20px;">
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:56px;vertical-align:top;padding-right:16px;">
                          <div style="width:48px;height:48px;background-color:#dde1ff;border-radius:50%;text-align:center;line-height:48px;">
                            <span style="color:#001356;font-size:24px;">🔍</span>
                          </div>
                        </td>
                        <td style="vertical-align:top;">
                          <h3 style="margin:0 0 8px;font-family:'Manrope',sans-serif;font-size:18px;font-weight:700;color:#191c1e;">
                            Curated Matches
                          </h3>
                          <p style="margin:0;font-family:'Inter',sans-serif;font-size:14px;color:#434656;line-height:1.5;">
                            Our algorithm highlights projects that perfectly align with your unique skill set.
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Seamless Earning -->
              <table cellpadding="0" cellspacing="0" style="width:100%;background-color:#ffffff;border-radius:8px;box-shadow:0 2px 8px rgba(25,28,30,0.02);">
                <tr>
                  <td style="padding:20px;">
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:56px;vertical-align:top;padding-right:16px;">
                          <div style="width:48px;height:48px;background-color:#6ffbbe;border-radius:50%;text-align:center;line-height:48px;">
                            <span style="color:#002113;font-size:24px;">💳</span>
                          </div>
                        </td>
                        <td style="vertical-align:top;">
                          <h3 style="margin:0 0 8px;font-family:'Manrope',sans-serif;font-size:18px;font-weight:700;color:#191c1e;">
                            Seamless Earning
                          </h3>
                          <p style="margin:0;font-family:'Inter',sans-serif;font-size:14px;color:#434656;line-height:1.5;">
                            Start working and getting paid faster with our streamlined contracting tools.
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- CTA Section -->
          <tr>
            <td style="padding:40px 32px;text-align:center;">

              <table cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td>
                    <table cellpadding="0" cellspacing="0" style="background:linear-gradient(45deg, #0040e0, #2e5bff);border-radius:24px;box-shadow:0 4px 12px rgba(0,64,224,0.2);">
                      <tr>
                        <td style="text-align:center;padding:16px 32px;">
                          <a href="<%= dashboardUrl %>" style="display:inline-flex;align-items:center;color:#ffffff;font-family:'Inter',sans-serif;font-size:14px;font-weight:700;text-decoration:none;text-transform:uppercase;letter-spacing:0.05em;">
                            Get Started Now
                            <span style="margin-left:8px;font-size:16px;">→</span>
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:40px 32px;text-align:center;background-color:#f7f9fb;margin-top:16px;">

              <table cellpadding="0" cellspacing="0" style="margin:0 auto 24px;">
                <tr>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#505f76;text-decoration:underline;">Privacy Policy</a>
                  </td>
                  <td style="color:#cbd5e1;font-size:12px;">•</td>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#505f76;text-decoration:underline;">Terms of Service</a>
                  </td>
                  <td style="color:#cbd5e1;font-size:12px;">•</td>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#505f76;text-decoration:underline;">Unsubscribe</a>
                  </td>
                </tr>
              </table>

              <p style="margin:0;font-family:'Inter',sans-serif;font-size:12px;color:#505f76;opacity:0.8;">
                © <%= year %> Lona. All rights reserved.
              </p>

            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
