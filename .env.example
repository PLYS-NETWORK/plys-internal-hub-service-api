# ─── Runtime ──────────────────────────────────────────────────────────────────
DEPLOY_ENV=local
NODE_ENV=development
PORT=3000

# ─── Microservice gRPC (Phase 6) ─────────────────────────────────────────────
IDENTITY_GRPC_PORT=5001
IDENTITY_GRPC_URL=127.0.0.1:5001
PROFILES_GRPC_PORT=5002
PROFILES_GRPC_URL=127.0.0.1:5002
PROJECTS_GRPC_PORT=5003
PROJECTS_GRPC_URL=127.0.0.1:5003
FINANCE_GRPC_PORT=5004
FINANCE_GRPC_URL=127.0.0.1:5004
PLATFORM_GRPC_PORT=5005
PLATFORM_GRPC_URL=127.0.0.1:5005

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=marketplace

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# SecretType: jwt_hmac_sha256 — HS256 signing keys, ≥ 32 UTF-8 bytes each, must differ.
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=marketplace-api-dev
JWT_AUDIENCE=marketplace-clients-dev
JWT_STRICT_CLAIMS=false

# ─── Security ─────────────────────────────────────────────────────────────────
SSO_TOKEN_ENCRYPTION_KEY=RG+58B3JNEdUimacQuH5Ne3mrizY0twfXd7HWITqjeA=
SSO_EXCHANGE_CODE_TTL=60
LOGIN_LOCKOUT_THRESHOLD=10
LOGIN_LOCKOUT_WINDOW_MIN=15
THROTTLE_REDIS_PREFIX=throttle:
PUBLIC_ENDPOINT_API_KEY=

# ─── HTTP / CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Frontend URLs ────────────────────────────────────────────────────────────
PLOYOS_URL=http://localhost:3000
LONA_URL=http://localhost:3001
INTERNAL_HUB_URL=http://localhost:3002

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_PLOYOS_EMAIL=no-reply@ployos.com
RESEND_LONA_EMAIL=hello@ployos.com

# ─── Payments ─────────────────────────────────────────────────────────────────
PAYMENT_PROCESSOR=polar
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_TOP_UP_PRODUCT_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/sso/google/callback

# ─── Files Module ─────────────────────────────────────────────────────────────
FILES_STORAGE_PROVIDER=local
FILES_MAX_SIZE_BYTES=52428800
FILES_ALLOWED_MIME=image/png,image/jpeg,application/pdf
FILES_USER_QUOTA_BYTES=524288000
FILES_USER_MAX_COUNT=1000
FILES_PURGE_AFTER_DAYS=30
FILES_MAX_IMAGE_PIXELS=

# ─── Files Module — Local Provider ────────────────────────────────────────────
FILES_LOCAL_PATH=./uploads
FILES_LOCAL_PUBLIC_BASE_URL=http://localhost:3000/uploads

# ─── AWS S3 / S3-Compatible Object Storage ────────────────────────────────────
AWS_S3_REGION=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_DEFAULT_BUCKET=
AWS_S3_PRESIGN_TTL_SECONDS=900
AWS_S3_ENDPOINT=


# ─── Copyleaks API Key (for plagiarism detection) ─────────────────────────────────
COPYLEAKS_API_KEY=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=app:dev:
REDIS_TLS=false
REDIS_DB=0

# ─── AI provider key vault (versioned envelope encryption) ───────────────────
# SecretType: aes_256_gcm_key_base64 — both keys below are independent but share
# the same format: exactly 32 bytes when base64-decoded (`openssl rand -base64 32`).
# Do NOT use JWT-style `openssl rand -base64 48` for these AES keys.
AI_KEYS_MASTER_KEY_v1=
AI_KEYS_CURRENT_MASTER_VERSION=1
FE_BFF_SECRET_v1=
FE_BFF_CURRENT_VERSION=1