<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lona - Reset Password</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
</head>
<body style="margin:0;padding:0;background-color:#f7f9fb;font-family:'Inter',sans-serif;">

  <!-- Email Container -->
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f7f9fb;padding:48px 0;">
    <tr>
      <td align="center">

        <!-- Header -->
        <table width="600" cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
          <tr>
            <td align="center" style="padding:32px 16px;">
              <h1 style="margin:0;font-family:'Manrope',sans-serif;font-size:24px;font-weight:800;letter-spacing:-0.025em;color:#0040e0;">Lona</h1>
            </td>
          </tr>
        </table>

        <!-- Main Content Card -->
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 20px 40px rgba(25,28,30,0.04);position:relative;">

          <!-- Decorative Gradient Top Border -->
          <tr>
            <td style="height:4px;background:linear-gradient(90deg, #0040e0, #2e5bff);"></td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:48px 32px;">

              <!-- Icon -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
                <tr>
                  <td style="width:48px;height:48px;background-color:#eceef0;border-radius:50%;text-align:center;vertical-align:middle;">
                    <span style="color:#0040e0;font-size:24px;line-height:48px;">🔓</span>
                  </td>
                </tr>
              </table>

              <!-- Headline -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
                <tr>
                  <td>
                    <h2 style="margin:0 0 24px;font-family:'Manrope',sans-serif;font-size:28px;font-weight:700;letter-spacing:-0.025em;color:#191c1e;line-height:1.2;">
                      Reset your password
                    </h2>
                    <p style="margin:0 0 16px;font-family:'Inter',sans-serif;font-size:16px;color:#434656;line-height:1.6;">
                      Hi <strong><%= userName %></strong>,
                    </p>
                    <p style="margin:0;font-family:'Inter',sans-serif;font-size:16px;color:#434656;line-height:1.6;">
                      We received a request to reset the password for your Lona account. To secure your account and set up a new password, please use the verification code below. This code is valid for the next <strong><%= expiryMinutes %> minutes</strong>.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- OTP Display -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 48px;width:100%;">
                <tr>
                  <td align="center">
                    <p style="margin:0 0 16px;font-family:'Inter',sans-serif;font-size:14px;color:#434656;text-transform:uppercase;letter-spacing:0.1em;font-weight:600;">
                      Your verification code
                    </p>
                    <table cellpadding="0" cellspacing="0" style="margin:0 auto;">
                      <tr>
                        <% otp.split('').forEach(function(digit, index) { %>
                          <td style="padding:0 4px;">
                            <div style="width:48px;height:56px;line-height:56px;text-align:center;font-family:'Manrope',sans-serif;font-size:24px;font-weight:700;color:#0040e0;background-color:#f2f4f6;border-radius:8px;border:2px solid #e6e8ea;">
                              <%= digit %>
                            </div>
                          </td>
                        <% }); %>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 32px;width:100%;">
                <tr>
                  <td style="height:1px;background-color:rgba(224,227,229,0.5);"></td>
                </tr>
              </table>

              <!-- Security Note -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
                <tr>
                  <td>
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:24px;vertical-align:top;padding-right:12px;">
                          <div style="width:18px;height:18px;background-color:#0040e0;border-radius:50%;text-align:center;line-height:18px;font-size:12px;color:#ffffff;font-weight:600;margin-top:1px;">i</div>
                        </td>
                        <td style="vertical-align:top;">
                          <p style="margin:0;font-family:'Inter',sans-serif;font-size:14px;color:#747688;line-height:1.5;">
                            If you didn't request a password reset, you can safely ignore this email. Your current password will remain unchanged and your account is secure.
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Additional Security Info -->
              <table cellpadding="0" cellspacing="0" style="background-color:#f2f4f6;border-radius:8px;padding:16px;margin:24px 0;">
                <tr>
                  <td>
                    <p style="margin:0;font-family:'Inter',sans-serif;font-size:13px;color:#434656;line-height:1.5;">
                      <strong>Security notice:</strong> Never share this code with anyone. Our team will never ask for your verification code. This code is valid for <strong><%= expiryMinutes %> minutes</strong> and can only be used once.
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table width="600" cellpadding="0" cellspacing="0" style="margin:48px 0 0;text-align:center;">
          <tr>
            <td style="padding:0 16px 40px;">

              <table cellpadding="0" cellspacing="0" style="margin:0 auto 16px;">
                <tr>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;text-decoration:underline;">Privacy Policy</a>
                  </td>
                  <td style="color:#cbd5e1;font-size:12px;">•</td>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;text-decoration:underline;">Terms of Service</a>
                  </td>
                  <td style="color:#cbd5e1;font-size:12px;">•</td>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;text-decoration:underline;">Unsubscribe</a>
                  </td>
                </tr>
              </table>

              <p style="margin:0;font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;">
                © <%= year %> Lona. All rights reserved.
              </p>

            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

</body>
</html>
