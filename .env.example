NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=marketplace

# Auth (JWT)
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRATION=7d

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URLs (platform-scoped)
# PLOYOS_URL = Business platform frontend
# LONA_URL   = Consultant platform frontend
PLOYOS_URL=http://localhost:3000
LONA_URL=http://localhost:3001

# Payment (polar | stripe)
PAYMENT_PROCESSOR=polar
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/sso/google/callback

# Copyleaks
COPYLEAKS_API_KEY=