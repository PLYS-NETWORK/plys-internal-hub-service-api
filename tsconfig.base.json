{
  "compileOnSave": false,
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "types": ["node"],
    "paths": {
      "@plys/libraries/proto": ["packages/proto/index.ts"],
      "@plys/libraries/shared-kernel": ["packages/shared-kernel/index.ts"],
      "@plys/libraries/database": ["packages/database/index.ts"],
      "@plys/libraries/database/*": ["packages/database/*"],
      "@plys/libraries/config": ["packages/config/index.ts"],
      "@plys/libraries/config/*": ["packages/config/*"],
      "@plys/libraries/common-nest/*": ["packages/common-nest/*"],
      "@plys/libraries/unit-of-work/*": ["packages/unit-of-work/*"],
      "@plys/libraries/unit-of-work-core": ["packages/unit-of-work-core/index.ts"],
      "@plys/libraries/transaction-coordinator": ["packages/transaction-coordinator/index.ts"],
      "@plys/libraries/profiles-port": ["packages/profiles-port/index.ts"],
      "@plys/libraries/api-contracts": ["packages/api-contracts/index.ts"],
      "@plys/libraries/api-contracts/*": ["packages/api-contracts/*"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
