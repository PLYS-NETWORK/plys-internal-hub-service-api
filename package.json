{
  "name": "plys-marketplace",
  "version": "0.0.0",
  "private": true,
  "description": "Plys marketplace monorepo — API gateway and microservices",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nx run-many -t build --projects=api-gateway,identity-service,profiles-service,projects-service,finance-service,platform-service,libraries",
    "lint": "nx run-many -t lint --all",
    "test": "nx run-many -t test --all",
    "affected": "nx affected -t lint test build",
    "format": "prettier --write \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate packages/database/migrations/$npm_config_name -d packages/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d packages/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d packages/database/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create packages/database/migrations/$npm_config_name",
    "db:seed": "pnpm exec nx run libraries:build && DEPLOY_ENV=local NODE_ENV=local pnpm exec ts-node -r tsconfig-paths/register packages/database/seeds/seed-runner.ts",
    "db:drop": "DEPLOY_ENV=local pnpm exec ts-node -r tsconfig-paths/register packages/database/scripts/drop-schema.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^5.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/ejs": "^3.1.5",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nx": "^20.8.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "msgpackr-extract",
      "unrs-resolver",
      "nx"
    ]
  }
}
