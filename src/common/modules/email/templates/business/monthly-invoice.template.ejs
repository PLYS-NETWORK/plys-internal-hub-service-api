<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ployos - Outstanding Bill Notice</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;800;900&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f7f9fb;
      font-family: 'Inter', sans-serif;
      padding: 32px 16px;
    "
  >
    <table
      width="600"
      cellpadding="0"
      cellspacing="0"
      style="width: 100%; max-width: 600px; margin: 0 auto"
    >
      <!-- TopAppBar (Header) -->
      <tr>
        <td style="background-color: #f7f9fb; padding: 48px 24px; text-align: center">
          <h1
            style="
              margin: 0;
              font-size: 24px;
              font-weight: 800;
              letter-spacing: -0.025em;
              color: #1e3a8a;
              font-family: 'Manrope', sans-serif;
            "
          >
            Ployos
          </h1>
        </td>
      </tr>

      <!-- Main Content Area -->
      <tr>
        <td>
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="
              background-color: #ffffff;
              border-radius: 12px;
              box-shadow: 0 12px 32px rgba(25, 28, 30, 0.06);
              overflow: hidden;
            "
          >
            <!-- Header Section -->
            <tr>
              <td style="padding: 48px 32px 32px">
                <!-- Receipt Icon -->
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 24px">
                  <tr>
                    <td
                      style="
                        width: 48px;
                        height: 48px;
                        border-radius: 50%;
                        background-color: #dce1ff;
                        text-align: center;
                        vertical-align: middle;
                        line-height: 48px;
                      "
                    >
                      <span style="color: #00236f; font-size: 22px">&#128203;</span>
                    </td>
                  </tr>
                </table>

                <h2
                  style="
                    font-family: 'Manrope', sans-serif;
                    font-size: 28px;
                    font-weight: 700;
                    letter-spacing: -0.025em;
                    color: #191c1e;
                    margin: 0 0 16px;
                  "
                >
                  Outstanding Bill Notice
                </h2>

                <p
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #444651;
                    margin: 0;
                  "
                >
                  Hi <strong><%= businessName %></strong>,<br /><br />
                  You have completed tasks ready for payment across your active projects.
                  Please review the breakdown below and settle the payment by
                  <strong><%= dueDate %></strong>.
                </p>
              </td>
            </tr>

            <!-- Completed Tasks (Bento-style cards) -->
            <tr>
              <td style="padding: 0 32px 32px">
                <h3
                  style="
                    font-family: 'Manrope', sans-serif;
                    font-size: 18px;
                    font-weight: 600;
                    letter-spacing: -0.025em;
                    color: #191c1e;
                    margin: 0 0 16px;
                  "
                >
                  Completed Tasks
                </h3>

                <% for (const item of lineItems) { %>
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                    background-color: #f2f4f6;
                    border-radius: 8px;
                    margin: 0 0 12px;
                  "
                >
                  <tr>
                    <td style="padding: 20px">
                      <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                          <td style="vertical-align: middle">
                            <!-- Status Badge -->
                            <table cellpadding="0" cellspacing="0" style="margin: 0 0 6px">
                              <tr>
                                <td
                                  style="
                                    background-color: #89f5e7;
                                    border-radius: 12px;
                                    padding: 2px 8px;
                                  "
                                >
                                  <span
                                    style="
                                      font-family: 'Inter', sans-serif;
                                      font-size: 10px;
                                      font-weight: 700;
                                      color: #00312c;
                                      text-transform: uppercase;
                                      letter-spacing: 0.025em;
                                    "
                                    >Completed</span
                                  >
                                </td>
                              </tr>
                            </table>

                            <p
                              style="
                                font-family: 'Inter', sans-serif;
                                font-size: 15px;
                                font-weight: 500;
                                color: #191c1e;
                                margin: 0;
                              "
                            >
                              <%= item.taskName %>
                            </p>
                          </td>
                          <td style="text-align: right; vertical-align: middle">
                            <span
                              style="
                                font-family: 'Manrope', sans-serif;
                                font-size: 18px;
                                font-weight: 700;
                                color: #191c1e;
                              "
                              >$<%= item.amount %></span
                            >
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
                <% } %>
              </td>
            </tr>

            <!-- Billing Breakdown -->
            <tr>
              <td style="padding: 0 32px 32px">
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="background-color: #eceef0; border-radius: 8px"
                >
                  <tr>
                    <td style="padding: 24px">
                      <h3
                        style="
                          font-family: 'Manrope', sans-serif;
                          font-size: 16px;
                          font-weight: 600;
                          color: #191c1e;
                          margin: 0 0 16px;
                        "
                      >
                        Billing Breakdown
                      </h3>

                      <!-- Subtotal -->
                      <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                          <td style="padding: 0 0 12px">
                            <table width="100%" cellpadding="0" cellspacing="0">
                              <tr>
                                <td>
                                  <span
                                    style="
                                      font-family: 'Inter', sans-serif;
                                      font-size: 14px;
                                      color: #444651;
                                    "
                                    >Subtotal (Sum of all tasks)</span
                                  >
                                </td>
                                <td style="text-align: right">
                                  <span
                                    style="
                                      font-family: 'Inter', sans-serif;
                                      font-size: 14px;
                                      font-weight: 500;
                                      color: #191c1e;
                                    "
                                    >$<%= taskTotal %></span
                                  >
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                        <!-- Commission -->
                        <tr>
                          <td style="padding: 0 0 12px">
                            <table width="100%" cellpadding="0" cellspacing="0">
                              <tr>
                                <td>
                                  <span
                                    style="
                                      font-family: 'Inter', sans-serif;
                                      font-size: 14px;
                                      color: #444651;
                                    "
                                    >Platform Commission Fee (25%)</span
                                  >
                                </td>
                                <td style="text-align: right">
                                  <span
                                    style="
                                      font-family: 'Inter', sans-serif;
                                      font-size: 14px;
                                      font-weight: 500;
                                      color: #191c1e;
                                    "
                                    >$<%= commissionAmount %></span
                                  >
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>

                      <!-- Total -->
                      <table
                        width="100%"
                        cellpadding="0"
                        cellspacing="0"
                        style="border-top: 1px solid rgba(197, 197, 211, 0.3)"
                      >
                        <tr>
                          <td style="padding: 16px 0 0">
                            <table width="100%" cellpadding="0" cellspacing="0">
                              <tr>
                                <td style="vertical-align: middle">
                                  <span
                                    style="
                                      font-family: 'Manrope', sans-serif;
                                      font-size: 18px;
                                      font-weight: 700;
                                      color: #191c1e;
                                    "
                                    >Total Amount Due</span
                                  >
                                </td>
                                <td style="text-align: right; vertical-align: middle">
                                  <span
                                    style="
                                      font-family: 'Manrope', sans-serif;
                                      font-size: 24px;
                                      font-weight: 800;
                                      color: #00236f;
                                    "
                                    >$<%= invoiceTotal %></span
                                  >
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- CTA Button -->
            <tr>
              <td style="padding: 16px 32px 48px">
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 24px">
                  <tr>
                    <td
                      style="
                        background: linear-gradient(135deg, #00236f 0%, #1e3a8a 100%);
                        border-radius: 6px;
                        box-shadow: 0 12px 32px rgba(25, 28, 30, 0.06);
                      "
                    >
                      <a
                        href="<%= payInvoiceUrl %>"
                        style="
                          display: inline-flex;
                          align-items: center;
                          color: #ffffff;
                          font-family: 'Manrope', sans-serif;
                          font-size: 14px;
                          font-weight: 700;
                          letter-spacing: 0.025em;
                          padding: 16px 32px;
                          text-decoration: none;
                        "
                      >
                        Proceed to Billing Page
                        <span style="margin-left: 8px; font-size: 18px">&rarr;</span>
                      </a>
                    </td>
                  </tr>
                </table>

                <p
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 14px;
                    color: #444651;
                    margin: 0;
                  "
                >
                  Payment is due by <strong><%= dueDate %></strong>. If you have questions about
                  this invoice, please contact our support team.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td
          style="
            background-color: #f7f9fb;
            padding: 40px 24px;
            text-align: center;
            margin-top: 32px;
          "
        >
          <h2
            style="
              font-family: 'Manrope', sans-serif;
              font-size: 18px;
              font-weight: 700;
              color: #1e3a8a;
              margin: 0 0 16px;
            "
          >
            Ployos
          </h2>

          <table cellpadding="0" cellspacing="0" style="margin: 0 auto 16px">
            <tr>
              <td style="padding: 0 16px">
                <a
                  href="#"
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #444651;
                    text-decoration: none;
                  "
                  >Privacy Policy</a
                >
              </td>
              <td style="padding: 0 16px">
                <a
                  href="#"
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #444651;
                    text-decoration: none;
                  "
                  >Terms of Service</a
                >
              </td>
              <td style="padding: 0 16px">
                <a
                  href="#"
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #444651;
                    text-decoration: none;
                  "
                  >Unsubscribe</a
                >
              </td>
              <td style="padding: 0 16px">
                <a
                  href="#"
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #444651;
                    text-decoration: none;
                  "
                  >Manage Preferences</a
                >
              </td>
            </tr>
          </table>

          <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #444651; margin: 0">
            &copy; <%= year %> Ployos Platform. All rights reserved.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
