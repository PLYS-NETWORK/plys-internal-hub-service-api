{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@plys/libraries/proto": ["../../packages/proto/index.ts"],
      "@plys/libraries/shared-kernel": ["../../packages/shared-kernel/index.ts"],
      "@plys/libraries/database": ["../../packages/database/index.ts"],
      "@plys/libraries/database/*": ["../../packages/database/*"],
      "@plys/libraries/config": ["../../packages/config/index.ts"],
      "@plys/libraries/config/*": ["../../packages/config/*"],
      "@plys/libraries/common-nest/*": ["../../packages/common-nest/*"],
      "@plys/libraries/unit-of-work/*": ["../../packages/unit-of-work/*"],
      "@plys/libraries/ai-provider-key": ["../../packages/ai-provider-key/index.ts"],
      "@plys/libraries/profiles-port": ["../../packages/profiles-port/index.ts"],
      "@modules/profiles/*": ["src/modules/profiles/*"],
      "@modules/business-onboarding/*": ["src/modules/business-onboarding/*"],
      "@modules/consultant-onboarding/*": ["src/modules/consultant-onboarding/*"],
      "@modules/admin-consultant-onboarding/*": ["src/modules/admin-consultant-onboarding/*"],
      "@modules/admin-onboarding-questions/*": ["src/modules/admin-onboarding-questions/*"],
      "@modules/consultant-skill-exam/*": ["src/modules/consultant-skill-exam/*"],
      "@modules/admin-consultant-skill-exam/*": ["src/modules/admin-consultant-skill-exam/*"],
      "@modules/notifications/*": ["../platform-service/src/modules/notifications/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*spec.ts"]
}
