<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ployos - Top-Up Cancelled</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;800;900&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f7f9fb;
      font-family: 'Inter', sans-serif;
      padding: 32px 16px;
    "
  >
    <table
      width="600"
      cellpadding="0"
      cellspacing="0"
      style="width: 100%; max-width: 600px; margin: 0 auto"
    >
      <!-- Header -->
      <tr>
        <td style="background-color: #f7f9fb; padding: 48px 24px; text-align: center">
          <h1
            style="
              margin: 0;
              font-size: 24px;
              font-weight: 800;
              letter-spacing: -0.025em;
              color: #1e3a8a;
              font-family: 'Manrope', sans-serif;
            "
          >
            Ployos
          </h1>
        </td>
      </tr>

      <!-- Main Content Area -->
      <tr>
        <td>
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="
              background-color: #ffffff;
              border-radius: 12px;
              box-shadow: 0 12px 32px rgba(25, 28, 30, 0.06);
              overflow: hidden;
            "
          >
            <!-- Hero Section -->
            <tr>
              <td style="padding: 48px 32px 32px">
                <!-- Status Chip -->
                <table
                  cellpadding="0"
                  cellspacing="0"
                  style="background-color: #ffe8a8; border-radius: 12px; margin: 0 0 24px"
                >
                  <tr>
                    <td style="padding: 6px 12px">
                      <table cellpadding="0" cellspacing="0">
                        <tr>
                          <td style="padding-right: 8px; vertical-align: middle">
                            <span style="color: #5b3a00; font-size: 18px">✕</span>
                          </td>
                          <td style="vertical-align: middle">
                            <span
                              style="
                                font-family: 'Manrope', sans-serif;
                                font-weight: 600;
                                font-size: 14px;
                                letter-spacing: 0.05em;
                                color: #5b3a00;
                                text-transform: uppercase;
                              "
                              >Top-Up Cancelled</span
                            >
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <h2
                  style="
                    font-family: 'Manrope', sans-serif;
                    font-size: 24px;
                    font-weight: 300;
                    letter-spacing: -0.025em;
                    color: #191c1e;
                    margin: 0 0 16px;
                  "
                >
                  Your top-up has been cancelled.
                </h2>

                <p
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #444651;
                    margin: 0;
                    max-width: 400px;
                  "
                >
                  Hi <strong><%= recipientName %></strong>,<br /><br />
                  Your pending top-up checkout has been cancelled. No charge was made to your
                  payment method.
                </p>
              </td>
            </tr>

            <!-- Ledger Details -->
            <tr>
              <td style="padding: 0 32px 48px">
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="background-color: #eceef0; border-radius: 12px"
                >
                  <tr>
                    <td style="padding: 32px">
                      <!-- Metadata Grid -->
                      <table width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 32px">
                        <!-- Row 1: Reference & Date -->
                        <tr>
                          <td style="width: 50%; padding: 0 16px 24px 0">
                            <p
                              style="
                                font-family: 'Inter', sans-serif;
                                font-size: 12px;
                                letter-spacing: 0.05em;
                                color: #444651;
                                text-transform: uppercase;
                                margin: 0 0 4px;
                              "
                            >
                              Transaction Reference
                            </p>
                            <p
                              style="
                                font-family: 'Inter', sans-serif;
                                font-size: 14px;
                                font-weight: 500;
                                color: #191c1e;
                                margin: 0;
                              "
                            >
                              #<%= transactionNumber %>
                            </p>
                          </td>
                          <td style="width: 50%; padding: 0 0 24px 16px">
                            <p
                              style="
                                font-family: 'Inter', sans-serif;
                                font-size: 12px;
                                letter-spacing: 0.05em;
                                color: #444651;
                                text-transform: uppercase;
                                margin: 0 0 4px;
                              "
                            >
                              Cancelled On
                            </p>
                            <p
                              style="
                                font-family: 'Inter', sans-serif;
                                font-size: 14px;
                                font-weight: 500;
                                color: #191c1e;
                                margin: 0;
                              "
                            >
                              <%= cancelDate %>
                            </p>
                          </td>
                        </tr>

                        <!-- Row 2: Charge Status -->
                        <tr>
                          <td colspan="2">
                            <p
                              style="
                                font-family: 'Inter', sans-serif;
                                font-size: 12px;
                                letter-spacing: 0.05em;
                                color: #444651;
                                text-transform: uppercase;
                                margin: 0 0 4px;
                              "
                            >
                              Charge Status
                            </p>
                            <table cellpadding="0" cellspacing="0">
                              <tr>
                                <td style="padding-right: 8px; vertical-align: middle">
                                  <span style="color: #444651; font-size: 20px">🛡️</span>
                                </td>
                                <td style="vertical-align: middle">
                                  <p
                                    style="
                                      font-family: 'Inter', sans-serif;
                                      font-size: 14px;
                                      font-weight: 500;
                                      color: #191c1e;
                                      margin: 0;
                                    "
                                  >
                                    No charge was made
                                  </p>
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>

                      <!-- Amount Block -->
                      <table
                        width="100%"
                        cellpadding="0"
                        cellspacing="0"
                        style="border-top: 1px solid rgba(197, 197, 211, 0.15); padding-top: 32px"
                      >
                        <tr>
                          <td style="vertical-align: bottom">
                            <p
                              style="
                                font-family: 'Inter', sans-serif;
                                font-size: 14px;
                                color: #444651;
                                margin: 0 0 4px;
                              "
                            >
                              Intended Amount
                            </p>
                            <p
                              style="
                                font-family: 'Manrope', sans-serif;
                                font-size: 32px;
                                font-weight: 700;
                                letter-spacing: -0.025em;
                                color: #191c1e;
                                margin: 0;
                                text-decoration: line-through;
                                opacity: 0.4;
                              "
                            >
                              <%= currency === 'USD' ? '$' : currency %><%= amount %>
                            </p>
                          </td>
                          <td style="text-align: right; vertical-align: bottom">
                            <table cellpadding="0" cellspacing="0" style="display: inline-table">
                              <tr>
                                <td
                                  style="
                                    width: 48px;
                                    height: 48px;
                                    border-radius: 50%;
                                    background-color: #e0e3e5;
                                    text-align: center;
                                    vertical-align: middle;
                                  "
                                >
                                  <span style="color: #444651; font-size: 24px">✕</span>
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Call to Action -->
            <tr>
              <td style="padding: 0 32px 48px">
                <table cellpadding="0" cellspacing="0" style="margin: 0 0 24px">
                  <tr>
                    <td
                      style="
                        background: linear-gradient(135deg, #00236f 0%, #1e3a8a 100%);
                        border-radius: 6px;
                      "
                    >
                      <a
                        href="<%= transactionsUrl %>"
                        style="
                          display: inline-block;
                          color: #ffffff;
                          font-family: 'Manrope', sans-serif;
                          font-size: 14px;
                          font-weight: 700;
                          letter-spacing: 0.025em;
                          padding: 16px 32px;
                          text-decoration: none;
                        "
                      >
                        View Transactions &rarr;
                      </a>
                    </td>
                  </tr>
                </table>

                <p
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 14px;
                    color: #444651;
                    margin: 0;
                  "
                >
                  You can initiate a new top-up at any time from your billing dashboard.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td
          style="
            background-color: #f7f9fb;
            padding: 40px 24px;
            text-align: center;
            margin-top: 32px;
          "
        >
          <h2
            style="
              font-family: 'Manrope', sans-serif;
              font-size: 18px;
              font-weight: 700;
              color: #1e3a8a;
              margin: 0 0 16px;
            "
          >
            Ployos
          </h2>

          <table cellpadding="0" cellspacing="0" style="margin: 0 auto 16px">
            <tr>
              <td style="padding: 0 16px">
                <a
                  href="#"
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #444651;
                    text-decoration: none;
                  "
                  >Privacy Policy</a
                >
              </td>
              <td style="padding: 0 16px">
                <a
                  href="#"
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #444651;
                    text-decoration: none;
                  "
                  >Terms of Service</a
                >
              </td>
              <td style="padding: 0 16px">
                <a
                  href="#"
                  style="
                    font-family: 'Inter', sans-serif;
                    font-size: 12px;
                    color: #444651;
                    text-decoration: none;
                  "
                  >Unsubscribe</a
                >
              </td>
            </tr>
          </table>

          <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #444651; margin: 0">
            &copy; <%= year %> Ployos Platform. All rights reserved.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
