<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Application Sent - Lona</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
</head>
<body style="margin:0;padding:0;background-color:#f7f9fb;font-family:'Inter',sans-serif;">

  <!-- Email Container -->
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f7f9fb;padding:48px 0;">
    <tr>
      <td align="center">

        <!-- Header -->
        <table width="600" cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
          <tr>
            <td align="center" style="padding:32px 16px;">
              <h1 style="margin:0;font-family:'Manrope',sans-serif;font-size:24px;font-weight:800;letter-spacing:-0.025em;color:#0040e0;">Lona</h1>
            </td>
          </tr>
        </table>

        <!-- Main Success Card -->
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 20px 40px rgba(25,28,30,0.04);position:relative;margin:0 0 32px;">

          <!-- Success Green Top Border -->
          <tr>
            <td style="height:8px;background-color:#007d55;"></td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:48px 32px;">

              <!-- Success Icon -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
                <tr>
                  <td style="width:64px;height:64px;background-color:rgba(0,125,85,0.1);border-radius:50%;text-align:center;vertical-align:middle;">
                    <span style="color:#007d55;font-size:32px;line-height:64px;">✓</span>
                  </td>
                </tr>
              </table>

              <!-- Headline -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
                <tr>
                  <td>
                    <h2 style="margin:0 0 8px;font-family:'Manrope',sans-serif;font-size:32px;font-weight:700;letter-spacing:-0.025em;color:#191c1e;line-height:1.2;">
                      Application Sent
                    </h2>
                    <p style="margin:0;font-family:'Inter',sans-serif;font-size:18px;color:#434656;line-height:1.6;">
                      Hi <strong><%= recipientName %></strong>, your application has been successfully submitted to the project owner.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Project Details Card -->
              <table cellpadding="0" cellspacing="0" style="width:100%;background-color:#f2f4f6;border-radius:8px;margin:0 0 32px;position:relative;overflow:hidden;">
                <tr>
                  <td style="background:rgba(0,64,224,0.05);position:absolute;top:0;left:0;right:0;bottom:0;"></td>
                </tr>
                <tr>
                  <td style="padding:24px;position:relative;">
                    <p style="margin:0 0 4px;font-family:'Inter',sans-serif;font-size:12px;color:#434656;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;">
                      Project Match
                    </p>
                    <h3 style="margin:0 0 16px;font-family:'Manrope',sans-serif;font-size:20px;font-weight:700;color:#191c1e;">
                      <%= projectTitle %>
                    </h3>
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:20px;vertical-align:top;padding-right:8px;">
                          <span style="color:#434656;font-size:16px;">📅</span>
                        </td>
                        <td style="vertical-align:top;">
                          <p style="margin:0;font-family:'Inter',sans-serif;font-size:14px;color:#434656;font-weight:500;">
                            Under review
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Application Details -->
              <table cellpadding="0" cellspacing="0" style="width:100%;margin:0 0 32px;">
                <tr>
                  <td>
                    <h4 style="margin:0 0 16px;font-family:'Manrope',sans-serif;font-size:16px;font-weight:700;color:#191c1e;">
                      Application Details
                    </h4>

                    <!-- Consultant Info -->
                    <table cellpadding="0" cellspacing="0" style="width:100%;margin:0 0 16px;">
                      <tr>
                        <td style="width:120px;padding:8px 12px;border-bottom:1px solid #e6e8ea;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#434656;">
                          Consultant
                        </td>
                        <td style="padding:8px 12px;border-bottom:1px solid #e6e8ea;font-family:'Inter',sans-serif;font-size:14px;color:#191c1e;">
                          <%= consultantFullName %>
                        </td>
                      </tr>
                    </table>

                    <!-- Address -->
                    <table cellpadding="0" cellspacing="0" style="width:100%;margin:0 0 16px;">
                      <tr>
                        <td style="width:120px;padding:8px 12px;border-bottom:1px solid #e6e8ea;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#434656;">
                          Address
                        </td>
                        <td style="padding:8px 12px;border-bottom:1px solid #e6e8ea;font-family:'Inter',sans-serif;font-size:14px;color:#191c1e;">
                          <%= consultantAddress %>
                        </td>
                      </tr>
                    </table>

                    <!-- Matched Skills -->
                    <table cellpadding="0" cellspacing="0" style="width:100%;">
                      <tr>
                        <td style="width:120px;padding:8px 12px;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#434656;vertical-align:top;">
                          Skills Match
                        </td>
                        <td style="padding:8px 12px;font-family:'Inter',sans-serif;font-size:14px;color:#191c1e;">
                          <% if (matchedSkills.length > 0) { %>
                            <% matchedSkills.forEach(function(skill, index) { %>
                              <span style="display:inline-block;padding:4px 12px;margin:2px 4px 2px 0;background-color:#dde1ff;color:#0040e0;border-radius:16px;font-size:12px;font-weight:500;"><%= skill %></span>
                            <% }); %>
                          <% } else { %>
                            <em style="color:#434656;">No specific skill requirements</em>
                          <% } %>
                        </td>
                      </tr>
                    </table>

                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table cellpadding="0" cellspacing="0" style="margin:0 0 16px;">
                <tr>
                  <td>
                    <table cellpadding="0" cellspacing="0" style="background:linear-gradient(45deg, #0040e0, #2e5bff);border-radius:24px;box-shadow:0 4px 12px rgba(0,64,224,0.2);">
                      <tr>
                        <td style="text-align:center;padding:16px 32px;">
                          <a href="#" style="display:inline-block;color:#ffffff;font-family:'Inter',sans-serif;font-size:14px;font-weight:600;text-decoration:none;text-transform:uppercase;letter-spacing:0.05em;width:100%;">
                            View Application Status
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

            </td>
          </tr>
        </table>

        <!-- Info Section -->
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#f2f4f6;border-radius:12px;margin:0 0 48px;">
          <tr>
            <td style="padding:24px;text-align:center;">
              <p style="margin:0 0 16px;font-family:'Inter',sans-serif;font-size:14px;color:#434656;line-height:1.5;">
                We'll notify you via email as soon as there's an update on your application. You can also check your dashboard for real-time status.
              </p>
              <p style="margin:0;font-family:'Inter',sans-serif;font-size:14px;color:#434656;line-height:1.5;">
                Need to make changes? <a href="#" style="color:#0040e0;text-decoration:underline;font-weight:500;">Contact Support</a>
              </p>
            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table width="600" cellpadding="0" cellspacing="0" style="text-align:center;">
          <tr>
            <td style="padding:0 16px 40px;border-top:1px solid #f2f4f6;padding-top:32px;">

              <table cellpadding="0" cellspacing="0" style="margin:0 auto 16px;">
                <tr>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;text-decoration:underline;">Privacy Policy</a>
                  </td>
                  <td style="color:#cbd5e1;font-size:12px;">•</td>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;text-decoration:underline;">Terms of Service</a>
                  </td>
                  <td style="color:#cbd5e1;font-size:12px;">•</td>
                  <td style="padding:0 16px;">
                    <a href="#" style="font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;text-decoration:underline;">Unsubscribe</a>
                  </td>
                </tr>
              </table>

              <p style="margin:0;font-family:'Inter',sans-serif;font-size:12px;color:#94a3b8;">
                © <%= year %> Lona. All rights reserved.
              </p>

            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

</body>
</html>
