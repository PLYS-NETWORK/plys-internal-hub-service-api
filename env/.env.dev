# Dev VPS — non-secret config (secrets injected at deploy via CI)
DEPLOY_ENV=dev
NODE_ENV=production
PORT=4001

# ─── Microservice gRPC ───────────────────────────────────────────────────────
# Bind vs connect:
#   • Each service LISTENS on 0.0.0.0:<port> (see grpc-bootstrap.util.ts) — do not set a bind host in env.
#   • Clients CONNECT via resolveGrpcUrl(): explicit *_GRPC_URL wins, else GRPC_HOST + *_GRPC_PORT.
# VPS (network_mode: host): GRPC_HOST=127.0.0.1 + ports below.
GRPC_HOST=127.0.0.1
IDENTITY_GRPC_PORT=5001
BUSINESS_GRPC_PORT=5002
CONSULTANT_GRPC_PORT=5003
INTERNAL_ADMIN_GRPC_PORT=5004
INTERNAL_TASK_REVIEWER_GRPC_PORT=5005
FINANCE_GRPC_PORT=5006
NOTIFICATIONS_GRPC_PORT=5007
PLATFORM_GRPC_PORT=5008
AI_PROVIDER_GRPC_PORT=5009
# Local Docker bridge: set per-service URLs instead, e.g. IDENTITY_GRPC_URL=identity-service:5001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USERNAME=plys_dev
DB_PASSWORD=
DB_DATABASE=plys-db-dev

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# SecretType: jwt_hmac_sha256 — injected at deploy (openssl rand -base64 48)
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRATION=15m
# SecretType: jwt_hmac_sha256 — must differ from JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=marketplace-api-dev
JWT_AUDIENCE=marketplace-clients-dev
JWT_STRICT_CLAIMS=false

# ─── Security ─────────────────────────────────────────────────────────────────
SSO_TOKEN_ENCRYPTION_KEY=
SSO_EXCHANGE_CODE_TTL=60
LOGIN_LOCKOUT_THRESHOLD=10
LOGIN_LOCKOUT_WINDOW_MIN=15
THROTTLE_REDIS_PREFIX=throttle:dev:
PUBLIC_ENDPOINT_API_KEY=
GRPC_SERVICE_SECRET=

# ─── HTTP / CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://dev.ployos.com,https://dev.lona.run,https://dev.lona.my
# Dev VPS only — when true, localhost/127.0.0.1 origins bypass ALLOWED_ORIGINS
CORS_ALLOW_LOCALHOST=true

# ─── Frontend URLs ────────────────────────────────────────────────────────────
PLOYOS_URL=https://dev.ployos.com
LONAOS_URL=https://dev.lona.run
INTERNAL_HUB_URL=https://dev.lona.my

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_PLOYOS_EMAIL=no-reply@ployos.com
RESEND_LONAOS_EMAIL=hello@ployos.com

# ─── Payments ─────────────────────────────────────────────────────────────────
PAYMENT_PROCESSOR=polar
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_TOP_UP_PRODUCT_ID=ce5e31d3-2983-4c00-a233-54fcf10e76d6
POLAR_SERVER=sandbox
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api-dev.lona.my/api/v1/auth/sso/google/callback

# ─── Files Module ─────────────────────────────────────────────────────────────
FILES_STORAGE_PROVIDER=s3
FILES_MAX_SIZE_BYTES=52428800
FILES_ALLOWED_MIME=image/png,image/jpeg,application/pdf
FILES_USER_QUOTA_BYTES=524288000
FILES_USER_MAX_COUNT=1000
FILES_PURGE_AFTER_DAYS=30
FILES_MAX_IMAGE_PIXELS=
FILES_LOCAL_PATH=./uploads
FILES_LOCAL_PUBLIC_BASE_URL=https://api-dev.lona.my/uploads

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_S3_REGION=nbg1
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_DEFAULT_BUCKET=ployos-storage
AWS_S3_PRESIGN_TTL_SECONDS=900
AWS_S3_ENDPOINT=nbg1.your-objectstorage.com

# ─── Copyleaks ────────────────────────────────────────────────────────────────
COPYLEAKS_API_KEY=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_KEY_PREFIX=app:dev:
REDIS_TLS=false
REDIS_DB=0

# ─── AI provider key vault ────────────────────────────────────────────────────
# SecretType: aes_256_gcm_key_base64 — injected at deploy (openssl rand -base64 32)
AI_KEYS_MASTER_KEY_v1=
AI_KEYS_CURRENT_MASTER_VERSION=1
FE_BFF_SECRET_v1=
FE_BFF_CURRENT_VERSION=1
