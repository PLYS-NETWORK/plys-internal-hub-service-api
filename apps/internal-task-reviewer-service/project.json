{
  "name": "internal-task-reviewer-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/internal-task-reviewer-service/src",
  "projectType": "application",
  "tags": ["scope:app", "type:service", "domain:internal-task-reviewer"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build && rm -rf dist/i18n && cp -r ../../packages/common-nest/i18n dist/i18n",
        "cwd": "apps/internal-task-reviewer-service"
      },
      "dependsOn": ["^build"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_ENV=development nest start --watch",
        "cwd": "apps/internal-task-reviewer-service"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint \"src/**/*.ts\" --max-warnings=0",
        "cwd": "apps/internal-task-reviewer-service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --config jest.config.js",
        "cwd": "apps/internal-task-reviewer-service"
      }
    }
  }
}
