{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@plys/libraries/proto": ["proto/index.ts"],
      "@plys/libraries/shared-kernel": ["shared-kernel/index.ts"],
      "@plys/libraries/database": ["database/index.ts"],
      "@plys/libraries/database/*": ["database/*"],
      "@plys/libraries/config": ["config/index.ts"],
      "@plys/libraries/config/*": ["config/*"],
      "@plys/libraries/common-nest/*": ["common-nest/*"],
      "@plys/libraries/unit-of-work/*": ["unit-of-work/*"],
      "@plys/libraries/unit-of-work-core": ["unit-of-work-core/index.ts"],
      "@plys/libraries/transaction-coordinator": ["transaction-coordinator/index.ts"],
      "@plys/libraries/profiles-port": ["profiles-port/index.ts"],
      "@plys/libraries/api-contracts": ["api-contracts/index.ts"],
      "@plys/libraries/api-contracts/*": ["api-contracts/*"]
    }
  },
  "include": [
    "proto/**/*.ts",
    "shared-kernel/**/*.ts",
    "database/**/*.ts",
    "config/**/*.ts",
    "common-nest/**/*.ts",
    "unit-of-work/**/*.ts",
    "unit-of-work-core/**/*.ts",
    "transaction-coordinator/**/*.ts",
    "profiles-port/**/*.ts",
    "api-contracts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*spec.ts"]
}
